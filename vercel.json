{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/cerrar-concursos",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/recordatorios-locales",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/recordatorio-activacion",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/alerta-ranking",
      "schedule": "0 */3 * * *"
    }
  ]
}
