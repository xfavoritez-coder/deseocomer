generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id          String   @id @default(cuid())
  nombre      String
  email       String   @unique
  password    String
  telefono    String?
  ciudad      String?  @default("santiago")
  cumpleDia   Int?
  cumpleMes   Int?
  cumpleAnio  Int?
  estiloAlimentario     String   @default("")
  comidasFavoritas      String[] @default([])
  fotoUrl             String    @default("")
  tipo                String    @default("usuario")
  emailVerificado     Boolean   @default(false)
  emailVerificadoAt   DateTime?
  geniePerfil         Json?
  tokenVerificacion   String?
  resetToken          String?
  resetTokenExpira    DateTime?
  ipRegistro          String    @default("")
  codigoRef                     String   @default("")
  totalPuntosHistoricos         Int      @default(0)
  totalConcursosParticipados    Int      @default(0)
  totalConcursosGanados         Int      @default(0)
  mejorPosicion                 Int?
  primerApoyoNotificado Boolean  @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  favoritos       Favorito[]
  resenas         Resena[]
  participaciones ParticipanteConcurso[]
  ganador1De      Concurso[] @relation("Ganador1")
  ganador2De      Concurso[] @relation("Ganador2")
  ganador3De      Concurso[] @relation("Ganador3")
  ganadorActualDe Concurso[] @relation("GanadorActual")
  mensajesVistos  MensajeVisto[]
  toastsDismissed ToastDismissed[]
  notificaciones  Notificacion[]
  comidasCustom   ComidaCustom[]
}

model Local {
  id            String   @id @default(cuid())
  slug          String?  @unique
  nombre        String
  nombreDueno   String?
  celularDueno  String?
  email         String   @unique
  password      String
  telefono      String?
  ciudad        String   @default("santiago")
  categoria     String?
  descripcion   String?
  historia      String?
  direccion     String?
  comuna        String?
  lat           Float?
  lng           Float?
  instagram     String?
  sitioWeb      String?
  horarios      Json?
  logoUrl       String?
  portadaUrl    String?
  galeria       Json?
  tags          String[] @default([])
  tieneMenu     Boolean  @default(false)
  tieneDelivery     Boolean  @default(false)
  comunasDelivery   String[] @default([])
  tieneRetiro       Boolean  @default(false)
  sirveEnMesa       Boolean  @default(true)
  linkPedido        String?  @default("")
  resetToken        String?
  resetTokenExpira  DateTime?
  nombreEncargado               String   @default("")
  registroRapido                Boolean  @default(false)
  verificado                    Boolean  @default(false)
  activo                        Boolean  @default(true)
  vistas                        Int      @default(0)
  primerParticipanteNotificado  Boolean  @default(false)
  activadoAt                    DateTime?
  recordatorio2d                Boolean  @default(false)
  recordatorio5d                Boolean  @default(false)
  recordatorio10d               Boolean  @default(false)
  captadorId      String?
  captadorCodigo  String?  @default("")
  esFounder       Boolean  @default(false)
  founderAt       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  menuItems   MenuItem[]
  concursos   Concurso[]
  promociones Promocion[]
  favoritos   Favorito[]
  resenas     Resena[]
  captador    Captador? @relation("CaptadorLocales", fields: [captadorId], references: [id])
}

model MenuItem {
  id          String   @id @default(cuid())
  localId     String
  categoria   String
  nombre      String
  descripcion String?
  precio      Float
  imagenUrl   String?
  destacado   Boolean  @default(false)
  createdAt   DateTime @default(now())

  local       Local    @relation(fields: [localId], references: [id])
}

enum EstadoConcurso {
  programado
  activo
  finalizado
  en_revision
  completado
  expirado
  en_disputa
  cancelado
}

model Concurso {
  id           String   @id @default(cuid())
  slug         String?  @unique
  localId      String
  premio       String
  descripcion  String?
  condiciones  String?
  imagenUrl    String?
  vistas       Int      @default(0)
  fechaInicio  DateTime @default(now())
  fechaFin     DateTime

  // Legacy fields (kept for backwards compat, use estado instead)
  activo            Boolean  @default(true)
  cancelado         Boolean  @default(false)
  motivoCancelacion String   @default("")
  premioEntregado   Boolean  @default(false)
  premioEntregadoAt DateTime?
  recordatorio48h   Boolean  @default(false)
  recordatorio7d    Boolean  @default(false)
  recordatorio24h   Boolean  @default(false)

  // New estado-based fields
  estado              EstadoConcurso @default(activo)
  ganador1Id          String?
  ganador2Id          String?
  ganador3Id          String?
  ganadorActualId     String?
  codigoEntrega       String?
  confirmacionToken   String?
  ganadorNotificadoAt DateTime?
  localNotificadoAt   DateTime?
  segundoNotificadoAt DateTime?
  terceroNotificadoAt DateTime?
  premioConfirmadoAt  DateTime?
  premioExpiradoAt    DateTime?
  disputaAt           DateTime?
  ganadorDescartadoRazon String?
  modalidadPremio   String[] @default([])
  fechaActivacion   DateTime?

  createdAt         DateTime @default(now())

  local         Local    @relation(fields: [localId], references: [id])
  participantes ParticipanteConcurso[]
  listaEspera   ListaEsperaConcurso[]
  ganador1      Usuario? @relation("Ganador1", fields: [ganador1Id], references: [id])
  ganador2      Usuario? @relation("Ganador2", fields: [ganador2Id], references: [id])
  ganador3      Usuario? @relation("Ganador3", fields: [ganador3Id], references: [id])
  ganadorActual Usuario? @relation("GanadorActual", fields: [ganadorActualId], references: [id])

  @@index([estado, fechaFin])
}

model ParticipanteConcurso {
  id          String   @id @default(cuid())
  concursoId  String
  usuarioId   String
  referidoPor      String?
  referidorDirectoId    String?
  referidorNivel2Id     String?
  puntosNivel2          Int      @default(0)
  puntosNivel2Pendientes Int     @default(0)
  esMadrugador              Boolean  @default(false)
  puntosMadrugador          Int      @default(0)
  puntosReferidosNuevos     Int      @default(0)
  puntosReferidosExistentes Int      @default(0)
  codigoInvitacion          String?
  puntos           Int      @default(1)
  puntosPendientes Int      @default(0)
  estado           String   @default("activo")
  createdAt        DateTime @default(now())

  concurso    Concurso @relation(fields: [concursoId], references: [id])
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([concursoId, usuarioId])
  @@index([usuarioId])
  @@index([referidorDirectoId])
  @@index([referidorNivel2Id])
}

model Promocion {
  id                  String   @id @default(cuid())
  slug                String?  @unique
  localId             String
  tipo                String
  titulo              String
  descripcion         String?
  condiciones         String?
  porcentajeDescuento Int?
  precioOriginal      Float?
  precioDescuento     Float?
  horaInicio          String
  horaFin             String
  diasSemana          Json
  activa              Boolean  @default(true)
  esCumpleanos        Boolean  @default(false)
  imagenUrl           String?
  vistas              Int      @default(0)
  modalidad           String[] @default([])
  fechaVencimiento    DateTime?
  createdAt           DateTime @default(now())

  local               Local    @relation(fields: [localId], references: [id])
}

model Favorito {
  id        String   @id @default(cuid())
  usuarioId String
  localId   String
  createdAt DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  local     Local    @relation(fields: [localId], references: [id])

  @@unique([usuarioId, localId])
}

model Resena {
  id              String    @id @default(cuid())
  usuarioId       String
  localId         String
  rating          Int
  comentario      String
  respuestaLocal  String?
  fechaRespuesta  DateTime?
  likes           Int       @default(0)
  createdAt       DateTime  @default(now())

  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
  local           Local     @relation(fields: [localId], references: [id])
}

model Captador {
  id          String   @id @default(cuid())
  nombre      String
  email       String   @unique
  telefono    String   @default("")
  rut         String   @default("")
  banco       String   @default("")
  tipoCuenta  String   @default("")
  numeroCuenta String  @default("")
  codigo      String   @unique
  activo      Boolean  @default(true)
  terminosAceptados   Boolean   @default(false)
  terminosAceptadosAt DateTime?
  createdAt   DateTime @default(now())
  locales     Local[]  @relation("CaptadorLocales")
  pagos       PagoCaptador[]
}

model PagoCaptador {
  id           String   @id @default(cuid())
  captadorId   String
  monto        Int
  referencia   String   @default("")
  createdAt    DateTime @default(now())
  captador     Captador @relation(fields: [captadorId], references: [id])
}

model ListaEsperaLocal {
  id        String   @id @default(cuid())
  email     String
  ciudad    String
  createdAt DateTime @default(now())
}

model ListaEsperaComuna {
  id          String   @id @default(cuid())
  email       String
  nombre      String?
  comuna      String
  usuarioId   String?
  notificado  Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ConfigSite {
  id    String @id @default("main")
  clave String @unique
  valor String
}

model MensajeGenio {
  id            String   @id @default(cuid())
  contenido     String
  tipo          String   @default("info")       // info, importante, promocion
  destinatario  String   @default("todos")      // "todos" o un usuarioId específico
  fijo          Boolean  @default(false)         // true = queda hasta que el usuario lo cierre
  duracion      Int?                             // segundos que se muestra (null = 8s default)
  activo        Boolean  @default(true)
  createdAt     DateTime @default(now())
  vistas        MensajeVisto[]
}

model MensajeVisto {
  id          String   @id @default(cuid())
  mensajeId   String
  usuarioId   String
  vistoAt     DateTime @default(now())
  dismissedAt DateTime?                          // null = solo visto, con fecha = cerró/dismiss
  noMostrar   Boolean  @default(false)           // true = marcó "no mostrar más"
  createdAt   DateTime @default(now())

  mensaje     MensajeGenio @relation(fields: [mensajeId], references: [id])
  usuario     Usuario      @relation(fields: [usuarioId], references: [id])

  @@unique([mensajeId, usuarioId])
}

model ToastDismissed {
  id        String   @id @default(cuid())
  usuarioId String
  toastId   String                               // ID del toast (ej: "cumpleanos", "concursos_ya_sabe")
  createdAt DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, toastId])
}

model Notificacion {
  id          String   @id @default(cuid())
  usuarioId   String
  tipo        String
  mensaje     String
  datos       Json?
  leida       Boolean  @default(false)
  createdAt   DateTime @default(now())
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
}

model CategoriaComida {
  id              String   @id @default(cuid())
  nombre          String   @unique
  slug            String   @unique
  emoji           String   @default("")
  tipo            String   @default("tag")       // "principal" | "tag"
  estiloExcluido  String[] @default([])           // ["vegano","vegetariano"] si no aplica
  visible         Boolean  @default(true)
  orden           Int      @default(99)
  creadoEn        DateTime @default(now())
}

model ComidaCustom {
  id              String   @id @default(cuid())
  texto           String                          // normalizado (lowercase, sin acentos)
  textoOriginal   String                          // tal cual lo escribió el usuario
  usuarioId       String
  promovidaA      String?                         // id de CategoriaComida si fue promovida
  ignorada        Boolean  @default(false)
  creadoEn        DateTime @default(now())

  usuario         Usuario  @relation(fields: [usuarioId], references: [id])

  @@index([texto])
}

model ListaEsperaConcurso {
  id          String   @id @default(cuid())
  concursoId  String
  email       String
  nombre      String?
  usuarioId   String?
  notificado  Boolean  @default(false)
  createdAt   DateTime @default(now())

  concurso    Concurso @relation(fields: [concursoId], references: [id])

  @@unique([concursoId, email])
}

model Campana {
  id               String   @id @default(cuid())
  asunto           String
  template         String   @default("founder")  // founder, generico, reactivacion
  estado           String   @default("borrador")  // borrador, enviando, completada
  totalContactos   Int      @default(0)
  totalEnviados    Int      @default(0)
  totalErrores     Int      @default(0)
  createdAt        DateTime @default(now())
  enviadoAt        DateTime?
  contactos        ContactoCampana[]
}

model ContactoCampana {
  id           String    @id @default(cuid())
  campanaId    String
  email        String
  nombre       String?
  abrioEmail   Boolean   @default(false)
  hizoClic     Boolean   @default(false)
  seRegistro   Boolean   @default(false)
  errorEnvio   String?
  abrioAt      DateTime?
  clicAt       DateTime?
  createdAt    DateTime  @default(now())
  campana      Campana   @relation(fields: [campanaId], references: [id])

  @@unique([campanaId, email])
  @@index([email])
}
